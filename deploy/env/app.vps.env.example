# SQL Server on VPS host
SQL_SERVER_HOST=host.docker.internal
SQL_SERVER_PORT=1433
SQL_SERVER_DB=usedCars

SQL_SERVER_USER=app_rw_user
SQL_SERVER_PASSWORD=change_me

SQL_READONLY_USER=rag_chatbot_readonly
SQL_READONLY_PASSWORD=change_me

# Qdrant in same Docker compose
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=xe_inventory_openai_small

# LLM gateway
LLM_MODEL=qwen/qwen3-32b
LLM_BASE_URL=https://llm-api-gateway-xlvu.onrender.com/v1
API_KEY=change_me

# Vehicle pricing vision
VISION_BASE_URL=https://platform.beeknoee.com/api/v1
VISION_API_KEY=change_me
VISION_MODEL=gemini-2.5-flash-lite

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DEVICE=none
EMBEDDING_BATCH_SIZE=32
EMBEDDING_BASE_URL=https://platform.beeknoee.com/api/v1
EMBEDDING_API_KEY=change_me

# Redis on VPS host
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SESSION_TTL=86400
REDIS_RECONCILE_INTERVAL=60
REDIS_RETRY_INTERVAL=5
REDIS_RETRY_MAX_ATTEMPTS=10

# App
ADMIN_API_KEY=change_me
MAX_HISTORY_TURNS=6
SQL_QUERY_TIMEOUT=10
SYNC_INTERVAL_MINUTES=15
QDRANT_SCORE_THRESHOLD=0.65

# Internal pricing
PRICING_INTERNAL_TOKEN=pricing_internal_local_token
PRICING_MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=useCars
PRICING_MONGO_DB=pricing
PRICING_MONGO_COLLECTION=ai_vehicle_valuations
PRICING_CLOUDINARY_ALLOWED_DOMAINS=res.cloudinary.com
PRICING_MAX_IMAGES=20
PRICING_SCHEMA_VERSION=vehicle-pricing-v2
PRICING_IMAGE_HASH_TIMEOUT_SECONDS=2

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
